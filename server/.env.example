# 后端环境变量配置
# 复制此文件为 .env 并修改

# JWT密钥（生产环境请使用强密码）
JWT_SECRET=your-jwt-secret-key-here

# 服务器端口
PORT=3001

# CORS允许的域名（多个用逗号分隔）
ALLOWED_ORIGINS=

# 数据库配置（如果使用PostgreSQL）
# DATABASE_URL=postgresql://username:password@localhost:5432/renyuan

# AI API密钥
# OPENAI_API_KEY=your-openai-api-key
# DEEPSEEK_API_KEY=your-deepseek-api-key
